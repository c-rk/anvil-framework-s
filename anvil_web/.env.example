# Base URL of the anvil_server FastAPI backend.
# Copy to `.env` (or `.env.local`) to override the default.
#
# Default behaviour without this file:
#   - served by the backend itself (python -m anvil_server.run): same origin
#   - Vite dev server (port 5173): http://127.0.0.1:8000
#VITE_API_BASE=http://127.0.0.1:8000
